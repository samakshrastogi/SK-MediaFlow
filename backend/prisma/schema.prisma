generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  username String? @unique
  password String?
  googleId String? @unique
  name     String? @db.String
  avatarKey String?
  coverKey  String?
  provider AuthProvider @default(LOCAL)
  isVerified Boolean @default(false)
  platformAdmin Boolean @default(false)
  otp       String?
  otpExpiry DateTime?
  resetToken    String?
  resetTokenExp DateTime?
  createdAt DateTime @default(now())
  channel Channel?
  s3Credentials S3Credential[]
  videoActions VideoAction[]
  playlists Playlist[]
  views VideoView[]
  reactions VideoReaction[]
  comments VideoComment[]
  shares VideoShare[]
  watchHistory WatchHistory[]
  subscriptions Subscription[] @relation("UserSubscriptions")
  organizationMemberships OrganizationMembership[]
  organizationInvitesSent OrganizationInvite[] @relation("InviteCreator")
  organizationInvitesAccepted OrganizationInvite[] @relation("InviteAccepter")
  organizationUploaderAccess OrganizationAllowedUploader[]
  ownedOrganizations Organization[] @relation("OrganizationOwner")
  notifications Notification[]
  logins UserLogin[]
  activeOrganizationId String? @db.ObjectId
  activeOrganization Organization? @relation("ActiveOrganization", fields: [activeOrganizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([name])
}

model UserLogin {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id])
  method LoginMethod @default(LOCAL)
  sessionLengthSec Int?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Channel {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  username String @unique
  description String?
  userId String @unique @db.ObjectId
  user User @relation(fields: [userId], references: [id])
  videos Video[]
  subscribers Subscription[] @relation("ChannelSubscribers")
  createdAt DateTime @default(now())
}

model Video {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  publicId String @unique @db.String
  title String
  s3Key String @unique
  size String
  thumbnailKey String?
  uploadSource UploadSource
  status UploadStatus @default(UPLOADING)
  visibility VideoVisibility @default(PUBLIC)
  channelId String @db.ObjectId
  channel Channel @relation(fields: [channelId], references: [id])
  organizationId String? @db.ObjectId
  organization Organization? @relation(fields: [organizationId], references: [id])
  aiData VideoAI?
  metadata VideoMetadata?
  videoActions VideoAction[]
  views VideoView[]
  reactions VideoReaction[]
  comments VideoComment[]
  shares VideoShare[]
  watchHistory WatchHistory[]
  createdAt DateTime @default(now())

  @@index([channelId])
  @@index([visibility])
  @@index([organizationId])
}

model VideoView {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  videoId String @db.ObjectId
  video Video @relation(fields: [videoId], references: [id])
  userId String? @db.ObjectId
  user User? @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([videoId])
  @@index([userId])
}

model VideoReaction {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id])
  videoId String @db.ObjectId
  video Video @relation(fields: [videoId], references: [id])
  type ReactionType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, videoId])
  @@index([videoId, type])
}

model VideoComment {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id])
  videoId String @db.ObjectId
  video Video @relation(fields: [videoId], references: [id])
  text String
  createdAt DateTime @default(now())

  @@index([videoId])
  @@index([userId])
}

model VideoShare {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id])
  videoId String @db.ObjectId
  video Video @relation(fields: [videoId], references: [id])
  method ShareMethod @default(COPY_LINK)
  createdAt DateTime @default(now())

  @@index([videoId])
  @@index([userId])
}

model Subscription {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  subscriberId String @db.ObjectId
  subscriber User @relation("UserSubscriptions", fields: [subscriberId], references: [id])
  channelId String @db.ObjectId
  channel Channel @relation("ChannelSubscribers", fields: [channelId], references: [id])
  createdAt DateTime @default(now())

  @@unique([subscriberId, channelId])
  @@index([channelId])
}

model WatchHistory {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id])
  videoId String @db.ObjectId
  video Video @relation(fields: [videoId], references: [id])
  watchedSeconds Int @default(0)
  lastPositionSeconds Int @default(0)
  lastWatchedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, videoId])
  @@index([userId, lastWatchedAt])
  @@index([videoId])
}

model Organization {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  slug String @unique
  joinToken String @unique
  privateJoinToken String @unique
  description String?
  ownerId String @db.ObjectId
  owner User @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  allowedDomain String?
  allowPublicContent Boolean @default(true)
  allowPrivateContent Boolean @default(false)
  restrictContentForAdmins Boolean @default(true)
  uploadPolicy OrganizationUploadPolicy @default(ADMINS_ONLY)
  trialStartAt DateTime @default(now())
  trialEndsAt DateTime
  billingStatus OrganizationBillingStatus @default(TRIAL_ACTIVE)
  subscriptionPlan OrganizationSubscriptionPlan @default(NONE)
  subscriptionEndsAt DateTime?
  blockedAt DateTime?
  members OrganizationMembership[]
  invites OrganizationInvite[]
  allowedUploaders OrganizationAllowedUploader[]
  videos Video[]
  activeUsers User[] @relation("ActiveOrganization")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationMembership {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String @db.ObjectId
  organization Organization @relation(fields: [organizationId], references: [id])
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id])
  role OrganizationRole @default(MEMBER)
  status OrganizationMembershipStatus @default(PENDING)
  requestedAt DateTime @default(now())
  approvedAt DateTime?
  leftAt DateTime?

  @@unique([organizationId, userId])
  @@index([organizationId, status])
  @@index([userId, status])
}

model OrganizationInvite {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String @db.ObjectId
  organization Organization @relation(fields: [organizationId], references: [id])
  email String
  status OrganizationInviteStatus @default(PENDING)
  token String @unique
  expiresAt DateTime
  createdByUserId String @db.ObjectId
  createdBy User @relation("InviteCreator", fields: [createdByUserId], references: [id])
  acceptedByUserId String? @db.ObjectId
  acceptedBy User? @relation("InviteAccepter", fields: [acceptedByUserId], references: [id])
  createdAt DateTime @default(now())
  acceptedAt DateTime?

  @@index([organizationId, email])
}

model OrganizationAllowedUploader {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String @db.ObjectId
  organization Organization @relation(fields: [organizationId], references: [id])
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([organizationId, userId])
}

model Notification {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id])
  title String
  message String
  link String?
  type NotificationType @default(GENERAL)
  isRead Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, isRead])
}

model S3Credential {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  accessKey String
  secretKey String
  region String?
  endpoint String?
  bucketName String
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
}

model VideoAI {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  videoId String @unique @db.ObjectId
  video Video @relation(fields: [videoId], references: [id])
  transcript String?
  keywords String[]
  tags String[]
  aiTitle String?
  aiDescription String?
  status String @default("pending")
  createdAt DateTime @default(now())
}

model VideoAction {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  videoId String @db.ObjectId
  actionType VideoActionType
  commentText String?
  playlistId String? @db.ObjectId
  user User @relation(fields: [userId], references: [id])
  video Video @relation(fields: [videoId], references: [id])
  playlist Playlist? @relation(fields: [playlistId], references: [id])
  createdAt DateTime @default(now())

  @@index([videoId])
  @@index([userId])
  @@index([actionType])
}

model Playlist {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  userId String @db.ObjectId
  user User @relation(fields: [userId], references: [id])
  actions VideoAction[]
  createdAt DateTime @default(now())

  @@index([userId])
}

model VideoMetadata {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  videoId String @unique @db.ObjectId
  video Video @relation(fields: [videoId], references: [id])
  duration Int
  totalFrames Int?
  width Int?
  height Int?
  aspectRatio String?
  orientation Orientation?
  fps Float?
  hasAudio Boolean @default(false)
  videoCodec String?
  audioCodec String?
  deviceInfo String?
  createdAt DateTime @default(now())
}

enum Orientation {
  PORTRAIT
  LANDSCAPE
  SQUARE
}

enum UploadStatus {
  UPLOADING
  UPLOADED
  FAILED
}

enum UploadSource {
  MANUAL
  S3_IMPORT
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum VideoActionType {
  LIKE
  DISLIKE
  COMMENT
  ADD_TO_PLAYLIST
  WATCH   
}

enum VideoVisibility {
  PUBLIC
  PRIVATE
  ORGANIZATION
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum ShareMethod {
  COPY_LINK
  NATIVE
  WHATSAPP
  TELEGRAM
  X
  FACEBOOK
  LINKEDIN
  EMAIL
}

enum OrganizationRole {
  ADMIN
  MEMBER
}

enum OrganizationMembershipStatus {
  PENDING
  APPROVED
  REJECTED
  LEFT
}

enum OrganizationInviteStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

enum OrganizationUploadPolicy {
  ALL_MEMBERS
  SPECIFIC_USERS
  ADMINS_ONLY
}

enum OrganizationBillingStatus {
  TRIAL_ACTIVE
  ACTIVE
  EXPIRED
}

enum OrganizationSubscriptionPlan {
  NONE
  TRIAL_FREE
  SIX_MONTH
  YEARLY_INITIAL
  YEARLY_RENEWAL
}

enum NotificationType {
  GENERAL
  ORG_INVITE
  ORG_APPROVED
  VIDEO
}

enum LoginMethod {
  LOCAL
  GOOGLE
}
