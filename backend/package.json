{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "dev": "ts-node --transpile-only src/server.ts",
    "worker:dev": "ts-node --transpile-only src/workers/index.ts",
    "s3:cors": "ts-node --transpile-only src/scripts/configure-s3-cors.ts",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "optimize:videos": "ts-node --transpile-only src/scripts/optimize-existing-videos.ts",
    "build": "tsc --pretty",
    "start": "node dist/server.js",
    "worker": "node dist/workers/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.999.0",
    "@aws-sdk/cloudfront-signer": "^3.999.0",
    "@aws-sdk/s3-request-presigner": "^3.999.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@prisma/client": "^6.19.2",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.1",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "multer": "^2.0.2",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.3",
    "ollama": "^0.6.3",
    "openai": "^6.27.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prisma": "^6.19.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/express-session": "^1.18.2",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "dotenv-cli": "^11.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
